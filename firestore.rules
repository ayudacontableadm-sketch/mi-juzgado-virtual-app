rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    match /users/{uid} {
      allow read: if owns(uid);
      // El cliente puede dar de alta su perfil una sola vez. Los campos de vínculo
      // no pueden modificarse desde la app; un cambio de equipo debe pasar por soporte.
      allow create: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.keys().hasAll(['uid', 'phoneNumber', 'createdAt', 'deviceId', 'accountStatus']);
      allow update: if owns(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.phoneNumber == resource.data.phoneNumber
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.deviceId == resource.data.deviceId
        && request.resource.data.accountStatus == resource.data.accountStatus;
    }
    match /deviceChangeRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
    }
    match /cases/{caseId} {
      allow read: if signedIn() && request.auth.uid == resource.data.uid;
      allow create, update: if signedIn() && request.auth.uid == request.resource.data.uid;
    }
    match /hearings/{hearingId} {
      allow read: if signedIn() && request.auth.uid == resource.data.uid;
      allow create, update: if signedIn() && request.auth.uid == request.resource.data.uid;
      match /messages/{messageId} {
        allow read, create: if signedIn();
      }
    }
  }
}
